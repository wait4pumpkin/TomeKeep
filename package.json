{
  "name": "tomekeep-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @tomekeep/desktop dev",
    "dev:web": "pnpm --filter @tomekeep/web dev:wrangler",
    "dev:full": "npx concurrently -n desktop,web -c cyan,green \"pnpm --filter @tomekeep/desktop dev\" \"pnpm --filter @tomekeep/web dev:wrangler\"",
    "build": "pnpm --filter @tomekeep/desktop build",
    "test": "pnpm --filter @tomekeep/desktop test && pnpm --filter @tomekeep/shared test",
    "lint": "pnpm -r lint",
    "electron:build": "pnpm --filter @tomekeep/desktop electron:build"
  }
}
