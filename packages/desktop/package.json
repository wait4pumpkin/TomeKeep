{
  "name": "@tomekeep/desktop",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "TOMEKEEP_API_URL=http://localhost:8788/api vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@tomekeep/shared": "workspace:*",
    "lowdb": "^7.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "selfsigned": "^5.5.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.4.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.tomekeep.app",
    "productName": "TomeKeep",
    "executableName": "TomeKeep",
    "icon": "build/icon.png",
    "afterPack": "./scripts/after-pack.cjs",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "identity": null,
      "extendInfo": {
        "NSCameraUsageDescription": "TomeKeep uses your camera to scan book ISBN barcodes."
      }
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron",
      "public"
    ]
  }
}
